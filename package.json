{
  "name": "spotterjs-workspace",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "build": "npm run build -w @spotterjs/base && npm run build -w @spotterjs/node && npm run build -w @spotterjs/core && npm run build -w @spotterjs/plugin-ocr && npm run build -w @spotterjs/plugin-android && npm run build -w @spotterjs/mcp",
    "build:ts": "npm run build -w @spotterjs/base && npm run build -w @spotterjs/core && npm run build -w @spotterjs/plugin-ocr && npm run build -w @spotterjs/plugin-android && npm run build -w @spotterjs/mcp",
    "build:native": "npm run build -w @spotterjs/node",
    "docs:check": "node scripts/check-doc-links.mjs",
    "prepare:native-packages": "node scripts/prepare-native-packages.mjs",
    "prepare:ocr-models": "node scripts/prepare-ocr-models.mjs",
    "publish:native:win": "npm run build -w @spotterjs/node && node scripts/prepare-native-package.mjs win32-x64-msvc && npm publish ./crates/spotterjs-node/win32-x64-msvc",
    "publish:native:linux": "npm run build:linux -w @spotterjs/node && node scripts/prepare-native-package.mjs linux-x64-gnu && npm publish ./crates/spotterjs-node/linux-x64-gnu",
    "sync-license": "node scripts/sync-license.mjs",
    "test": "npm run test:unit && npm run test:types",
    "test:unit": "npm run test:rust && npm run test --workspaces --if-present",
    "test:types": "npm run test:types -w @spotterjs/core",
    "test:integration": "npm run test:rust:ignored && npm run smoke:noninteractive",
    "test:rust": "cargo test",
    "test:rust:ignored": "cargo test -- --ignored",
    "benchmark:ci": "tsx scripts/benchmark/run.ts --suite synthetic",
    "benchmark:deep": "tsx scripts/benchmark/run.ts --suite deep",
    "benchmark:ncc": "tsx scripts/benchmark/ncc-multiscale.ts",
    "benchmark:ncc:rust": "cargo run -p spotterjs-plugin-match-ncc --release --example bench_ncc -- test-output/capture.png test-output/needle.png",
    "smoke": "tsx scripts/smoke/run-all.ts",
    "smoke:noninteractive": "tsx scripts/smoke/run-noninteractive.ts",
    "smoke:version": "tsx scripts/smoke/01-version-screen.ts",
    "smoke:capture": "tsx scripts/smoke/02-capture.ts",
    "smoke:clipboard": "tsx scripts/smoke/03-clipboard.ts",
    "smoke:windows": "tsx scripts/smoke/04-windows.ts",
    "smoke:match": "tsx scripts/smoke/05-match-self.ts",
    "smoke:ocr": "tsx scripts/smoke/ocr-synthetic.ts",
    "smoke:match-tap": "tsx scripts/smoke/08-match-tap-coords.ts",
    "smoke:ncc:synthetic": "tsx scripts/smoke/ncc-synthetic-scenarios.ts",
    "smoke:a11y": "tsx scripts/smoke/06-accessibility-notepad.ts",
    "smoke:desktop": "tsx scripts/smoke/07-desktop-apps.ts",
    "smoke:android": "tsx scripts/smoke/android-companion.ts",
    "examples:paint": "tsx examples/paint/run-all.ts",
    "example:paint:open-focus": "tsx examples/paint/01-open-focus.ts",
    "example:paint:capture": "tsx examples/paint/02-capture-window.ts",
    "example:paint:match-tool": "tsx examples/paint/03-match-tool.ts",
    "example:paint:click-tool": "tsx examples/paint/04-click-tool.ts",
    "example:paint:input": "tsx examples/paint/05-keyboard-mouse.ts",
    "example:paint:ui-tree": "tsx examples/paint/06-ui-tree-dump.ts",
    "example:paint:ui-query": "tsx examples/paint/07-ui-tree-query.ts",
    "integration:wechat:dump": "tsx scripts/integration/06-uia-dump-wechat.ts",
    "integration:wechat:match": "tsx scripts/integration/wechat-match.ts",
    "integration:wechat:send": "tsx scripts/integration/wechat-send.ts",
    "changeset": "changeset",
    "sync:native-versions": "node scripts/sync-native-package-versions.mjs",
    "version-packages": "changeset version && npm run sync:native-versions",
    "release": "npm run sync-license && changeset publish",
    "verify-pack": "node scripts/verify-pack.mjs",
    "verify:native-install": "node scripts/verify-local-native-install.mjs"
  },
  "workspaces": [
    "packages/base",
    "packages/core",
    "packages/mcp",
    "packages/plugin-ocr",
    "packages/plugin-android",
    "crates/spotterjs-node"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@spotterjs/core": "1.0.3",
    "@spotterjs/plugin-ocr": "1.0.3",
    "@spotterjs/plugin-android": "1.0.3",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0",
    "tinybench": "^2.9.0",
    "tsx": "^4.19.0"
  }
}

{
    "name": "@spotterjs/core",
    "version": "1.0.2",
    "description": "spotterjs desktop automation - TypeScript API",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./native": {
            "types": "./dist/native.d.ts",
            "require": "./dist/native.js",
            "default": "./dist/native.js"
        },
        "./package.json": "./package.json"
    },
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://gitee.com/ypl0lpy/spotterjs.git",
        "directory": "packages/core"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "bugs": {
        "url": "https://gitee.com/ypl0lpy/spotterjs/issues"
    },
    "homepage": "https://gitee.com/ypl0lpy/spotterjs#readme",
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "prepublishOnly": "npm run build && node ../../scripts/sync-license.mjs"
    },
    "dependencies": {
        "@spotterjs/base": "1.0.2",
        "@spotterjs/node": "1.0.2"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "vitest": "^3.0.0"
    }
}

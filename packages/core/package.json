{
    "name": "@spotterjs/core",
    "version": "1.0.5",
    "description": "spotterjs desktop automation - TypeScript API",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./unstable-native": {
            "types": "./dist/unstable-native.d.ts",
            "require": "./dist/unstable-native.js",
            "default": "./dist/unstable-native.js"
        },
        "./native": {
            "types": "./dist/unstable-native.d.ts",
            "require": "./dist/unstable-native.js",
            "default": "./dist/unstable-native.js"
        },
        "./package.json": "./package.json"
    },
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/yinpeilin/spotterjs.git",
        "directory": "packages/core"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "bugs": {
        "url": "https://github.com/yinpeilin/spotterjs/issues"
    },
    "homepage": "https://github.com/yinpeilin/spotterjs#readme",
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:types": "tsc -p tsconfig.type-tests.json --noEmit",
        "prepublishOnly": "npm run build && node ../../scripts/sync-license.mjs"
    },
    "dependencies": {
        "@spotterjs/base": "1.0.5",
        "@spotterjs/node": "1.0.5"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.4.0",
        "vitest": "^3.0.0"
    }
}

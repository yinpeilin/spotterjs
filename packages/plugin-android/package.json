{
  "name": "@spotterjs/plugin-android",
  "version": "1.0.5",
  "description": "Android companion app automation plugin for spotterjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "android",
    "companion",
    "automation",
    "spotterjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yinpeilin/spotterjs.git",
    "directory": "packages/plugin-android"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/yinpeilin/spotterjs/issues"
  },
  "homepage": "https://github.com/yinpeilin/spotterjs#readme",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build && node ../../scripts/sync-license.mjs"
  },
  "dependencies": {
    "@spotterjs/base": "1.0.5",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}

{
    "name": "@spotterjs/mcp",
    "version": "1.0.3",
    "description": "spotterjs MCP server - desktop automation, workspace files, and shell",
    "license": "SEE LICENSE IN LICENSE",
    "type": "module",
    "main": "dist/server.js",
    "types": "dist/server.d.ts",
    "exports": {
        ".": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js",
            "default": "./dist/server.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "bin": {
        "spotterjs-mcp": "dist/cli.js"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/cli.js",
        "prepublishOnly": "npm run build && node ../../scripts/sync-license.mjs",
        "test": "vitest run"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.0",
        "@spotterjs/core": "1.0.3",
        "@spotterjs/plugin-android": "1.0.3",
        "@spotterjs/plugin-ocr": "1.0.3",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@spotterjs/plugin-android": "1.0.3",
        "@types/node": "^22.0.0",
        "typescript": "^5.4.0",
        "vitest": "^3.0.0"
    }
}

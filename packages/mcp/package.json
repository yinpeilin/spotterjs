                                                                      "optional":  true
                                                                  }
                             },
    "devDependencies":  {
                            "@spotterjs/plugin-android-adb":  "0.1.0",
                            "@types/node":  "^22.0.0",
                            "typescript":  "^5.4.0",
                            "vitest":  "^3.0.0"
                        }
}
